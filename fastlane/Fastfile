default_platform(:ios)

platform :ios do
  lane :release do
    api_key = app_store_connect_api_key(
      key_id:       ENV["APPLE_KEY_ID"],
      issuer_id:    ENV["APPLE_ISSUER_ID"],
      key_filepath: ENV["APPLE_KEY_PATH"],
      in_house:     false
    )

    cert(api_key: api_key)

    sigh(
      api_key:        api_key,
      app_identifier: "org.yogasupport.booking",
      force:          true
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path:                  "ios/YogaSupport.xcodeproj",
      team_id:               "G7LJ79QYX8",
      bundle_identifier:     "org.yogasupport.booking",
      code_sign_identity:    "Apple Distribution",
      profile_name:          ENV["SIGH_NAME"]
    )

    gym(
      workspace:        "ios/YogaSupport.xcworkspace",
      scheme:           "YogaSupport",
      export_method:    "app-store",
      output_directory: "./build",
      output_name:      "YogaSupport.ipa",
      clean:            true,
      xcargs:           "DEVELOPMENT_TEAM=G7LJ79QYX8 ENABLE_USER_SCRIPT_SANDBOXING=NO -allowProvisioningUpdates",
      export_options: {
        provisioningProfiles: {
          "org.yogasupport.booking" => ENV["SIGH_NAME"]
        }
      }
    )

    upload_to_app_store(
      api_key:                           api_key,
      ipa:                               "./build/YogaSupport.ipa",
      skip_metadata:                     true,
      skip_screenshots:                  true,
      submit_for_review:                 false,
      precheck_include_in_app_purchases: false,
      force:                             true
    )
  end

  # If anything fails, pull the real error out of Xcode's detailed log
  # and print it at the very bottom of the log so it's easy to find.
  error do |lane, exception|
    sh("echo '================ REAL ERROR EXCERPT (from gym log) ================'")
    sh("grep -i -E 'error|fail|cannot|not found|unable|no such|undefined|exception' ~/Library/Logs/gym/*.log 2>/dev/null | tail -n 60 || true")
    sh("echo '================ END REAL ERROR EXCERPT ================'")
  end
end
