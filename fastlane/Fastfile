default_platform(:ios)

platform :ios do
  desc "Build and upload to App Store"
  # IMPORTANT: keep this lane name the same as whatever your
  # .github/workflows/build.yml calls (e.g. `fastlane build`).
  lane :build do
    # 1. Authenticate with App Store Connect.
    #    Leave this exactly as it is in YOUR current Fastfile — it already works.
    app_store_connect_api_key

    # 2. Signing certificate
    cert

    # 3. Provisioning profile
    sigh

    # 4. Build the app.
    #    The two lines below are the actual fix.
    gym(
      workspace: "ios/YogaSupport.xcworkspace",   # confirmed correct from your logs
      scheme: "YogaSupport",                       # <-- MUST match the exact scheme name in Xcode
      export_method: "app-store"
    )

    # 5. Upload (keep your existing upload step / options here)
    upload_to_app_store(
      skip_metadata: true,
      skip_screenshots: true
    )
  end
end
